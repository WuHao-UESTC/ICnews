# Notion Integration
NOTION_TOKEN=ntn_your_integration_token_here
NOTION_PARENT_PAGE_ID=your_parent_page_id_here

# DeepSeek API (OpenAI-compatible)
DEEPSEEK_API_KEY=sk_your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# IEEE Xplore API (free student key from developer.ieee.org)
IEEE_API_KEY=your_ieee_api_key_here

# Optional: HTTP proxy for local development behind GFW
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Optional: filter sources by language (en, zh, or leave empty for all)
SOURCE_LANGUAGES=
